{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "changelog-sections": [
      {
        "section": "🎉 Features",
        "type": "feat"
      },
      {
        "section": "🐛 Bug Fixes",
        "type": "fix"
      },
      {
        "section": "⚡ Performance Improvements",
        "type": "perf"
      },
      {
        "section": "🔗 Dependencies",
        "type": "deps"
      },
      {
        "section": "📝 Documentation",
        "type": "docs"
      },
      {
        "section": "🏗️ Build System",
        "type": "build"
      },
      {
        "section": "🔧 Miscellaneous Chores",
        "type": "chore"
      },
      {
        "section": "⏪ Reverts",
        "type": "revert"
      },
      {
        "section": "✅ Tests",
        "type": "test"
      },
      {
        "section": "💄 Style",
        "type": "style"
      },
      {
        "section": "♻️ Code Refactoring",
        "type": "refactor"
      },
      {
        "section": "Helm Chart Updates",
        "type": "helm",
        "hidden": false
      }
    ],
    "draft-pull-request": false,
    "include-v-in-tag": true,
    "separate-pull-requests": true,
    "packages": {
      "core-stack": {
        "release-type": "helm",
        "extra-files": ["README.md"]
      },
      "sftpgo": {
        "release-type": "helm",
        "extra-files": ["README.md"]
      },
      "routes": {
        "release-type": "helm",
        "extra-files": ["README.md"]
      },
      "gatekeeper": {
        "release-type": "helm",
        "extra-files": ["README.md"]
      },
      "resource-scaler": {
        "release-type": "helm",
        "extra-files": ["README.md"]
      }
    }
}
